#!/bin/sh

rootdir() {
    current_dir="$PWD"
    while [ "$current_dir" != "/" ]; do
        if [ -f "$current_dir/@file" ]; then
            echo "$current_dir"
            exit 0
        fi
        current_dir=$(dirname "$current_dir")
    done
    exit 1
}

ROOT_DIR=$(rootdir @file)
cd $ROOT_DIR

# Check if an argument is provided
if [ $# -eq 0 ]; then
    echo "No argument provided. Please provide an argument."
    exit 1
fi

script="$1"
shift
args="$@"
./@"$script".sh "$@"
exit 0
